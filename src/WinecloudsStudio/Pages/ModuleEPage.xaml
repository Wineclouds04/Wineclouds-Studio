<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinecloudsStudio.Pages.ModuleEPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource ContentSurfaceBrush}"
    mc:Ignorable="d">
    <Grid Padding="40">
        <StackPanel Spacing="20">
            <TextBlock FontSize="30" FontWeight="SemiBold" Text="模块 E" />
            <TextBlock Foreground="#64748B" Text="模块 E 的服务入口将在此展示。" />
            <Border MinHeight="220" Padding="28" Background="White" BorderBrush="{StaticResource PlaceholderBorderBrush}" BorderThickness="1" CornerRadius="12">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                    <TextBlock HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="模块 E" />
                    <TextBlock HorizontalAlignment="Center" Foreground="#64748B" Text="功能建设中" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Page>
