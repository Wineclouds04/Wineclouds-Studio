<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="WinecloudsStudio.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WinecloudsStudio">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="NavigationPaneBrush" Color="#EFF6FF" />
            <SolidColorBrush x:Key="NavigationPaneForegroundBrush" Color="#1E293B" />
            <SolidColorBrush x:Key="NavigationGroupLabelBrush" Color="#64748B" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelected" Color="#DBEAFE" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="#1D4ED8" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundPointerOver" Color="#E0F2FE" />
            <SolidColorBrush x:Key="NavigationViewItemForegroundPointerOver" Color="#1E3A8A" />
            <SolidColorBrush x:Key="ContentSurfaceBrush" Color="#FFFFFF" />
            <SolidColorBrush x:Key="PlaceholderBorderBrush" Color="#CBD5E1" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
