<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WinecloudsStudio.Modules.ScreenDetection.Pages.ScreenDetectionPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{StaticResource ContentSurfaceBrush}"
    Loaded="Page_Loaded"
    mc:Ignorable="d">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel
            Width="{Binding ActualWidth, ElementName=RootPage}"
            Padding="40"
            Spacing="20">
            <StackPanel Spacing="5">
                <TextBlock FontSize="30" FontWeight="SemiBold" Text="屏幕区域检测" />
                <TextBlock
                    Foreground="#64748B"
                    Text="监控指定屏幕区域；目标色块稳定出现时循环播放提醒声音。"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Grid Height="720" ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="3*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                <Border
                    Padding="20"
                    Background="White"
                    BorderBrush="{StaticResource PlaceholderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="10">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="检测区域（物理像素）" />
                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="XBox" Header="X" />
                            <TextBox x:Name="YBox" Grid.Column="1" Header="Y" />
                            <TextBox x:Name="WidthBox" Grid.Column="2" Header="宽度" />
                            <TextBox x:Name="HeightBox" Grid.Column="3" Header="高度" />
                            <Button
                                x:Name="SelectRegionButton"
                                Grid.Column="4"
                                VerticalAlignment="Bottom"
                                Click="SelectRegionButton_Click"
                                Content="框选区域" />
                        </Grid>
                    </StackPanel>
                </Border>

                <Border
                    Grid.Row="1"
                    Padding="20"
                    Background="White"
                    BorderBrush="{StaticResource PlaceholderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="12">
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="目标颜色"
                                VerticalAlignment="Center" />
                            <Border
                                x:Name="TargetColorSwatch"
                                Grid.Column="1"
                                Width="48"
                                Height="30"
                                BorderBrush="#CBD5E1"
                                BorderThickness="1"
                                CornerRadius="6" />
                            <TextBlock
                                x:Name="TargetColorText"
                                Grid.Column="2"
                                FontFamily="Consolas"
                                Text="#FF0000"
                                VerticalAlignment="Center" />
                            <Button Grid.Column="3" Content="选择颜色" HorizontalAlignment="Left">
                                <Button.Flyout>
                                    <Flyout Placement="Bottom">
                                        <ColorPicker
                                            x:Name="TargetColorPicker"
                                            ColorChanged="TargetColorPicker_ColorChanged"
                                            IsAlphaEnabled="False" />
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                        </Grid>

                        <Border Height="1" Background="#E2E8F0" />

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                FontWeight="SemiBold"
                                Text="声音提醒"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="AudioFileText"
                                Grid.Column="1"
                                Foreground="#64748B"
                                Text="未选择 MP3"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center" />
                            <Button
                                x:Name="SelectAudioButton"
                                Grid.Column="2"
                                Click="SelectAudioButton_Click"
                                Content="选择 MP3" />
                        </Grid>
                    </StackPanel>
                </Border>
                <Border
                    Grid.Row="3"
                    Padding="20"
                    Background="White"
                    BorderBrush="{StaticResource PlaceholderBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <StackPanel Spacing="16">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="高级检测参数" />
                        <Grid ColumnSpacing="12" RowSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="HueToleranceBox" Header="色相容差（0–180°）" />
                        <TextBox x:Name="SaturationToleranceBox" Grid.Column="1" Header="饱和度容差（0–1）" />
                        <TextBox x:Name="ValueToleranceBox" Grid.Column="2" Header="亮度容差（0–1）" />
                        <TextBox x:Name="MinimumPixelsBox" Grid.Row="1" Header="最少目标色像素" />
                        <TextBox x:Name="MinimumAreaBox" Grid.Row="1" Grid.Column="1" Header="最小连通面积" />
                        <TextBox x:Name="ScanIntervalBox" Grid.Row="1" Grid.Column="2" Header="扫描间隔（ms）" />
                        <TextBox x:Name="PresentFramesBox" Grid.Row="2" Header="出现确认帧数" />
                        <TextBox x:Name="AbsentFramesBox" Grid.Row="2" Grid.Column="1" Header="消失确认帧数" />
                        </Grid>
                    </StackPanel>
                </Border>

            <Border
                Grid.Row="2"
                Padding="20"
                Background="White"
                BorderBrush="{StaticResource PlaceholderBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="5">
                        <TextBlock x:Name="StateText" FontSize="24" FontWeight="SemiBold" Text="未开始" />
                        <TextBlock x:Name="MetricsText" Foreground="#64748B" Text="等待开始检测" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Button x:Name="StartButton" Click="StartButton_Click" Content="开始检测" />
                        <Button x:Name="StopButton" Click="StopButton_Click" Content="停止" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>

                </Grid>

            <Border
                Grid.Column="1"
                Background="#111827"
                BorderBrush="{StaticResource PlaceholderBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Grid>
                    <Image x:Name="PreviewImage" Stretch="Uniform" />
                    <TextBlock
                        x:Name="PreviewPlaceholder"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Foreground="#CBD5E1"
                        Text="选择有效区域后显示实时画面" />
                    <Border
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="12"
                        Padding="8,4"
                        Background="#CC111827"
                        CornerRadius="4">
                        <TextBlock x:Name="PreviewInfoText" Foreground="White" Text="未选择区域" />
                    </Border>
                </Grid>
            </Border>
            </Grid>

            <TextBlock
                x:Name="ErrorText"
                Foreground="#B42318"
                TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
