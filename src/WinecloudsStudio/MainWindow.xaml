<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinecloudsStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinecloudsStudio"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Wineclouds Studio"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RequestedTheme="Light">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Background="White" Title="WinecloudsStudio" />

        <NavigationView
            x:Name="NavigationView"
            Grid.Row="1"
            AlwaysShowHeader="True"
            Background="{StaticResource NavigationPaneBrush}"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            ItemInvoked="NavigationView_ItemInvoked"
            PaneDisplayMode="Left"
            SelectionFollowsFocus="Enabled">
            <NavigationView.PaneHeader>
                <StackPanel Margin="12,8,0,8">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource NavigationPaneForegroundBrush}"
                        Text="Wineclouds Studio" />
                    <TextBlock
                        Margin="0,4,0,0"
                        Foreground="{StaticResource NavigationGroupLabelBrush}"
                        Text="桌面服务平台" />
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <TextBlock
                    x:Name="VersionText"
                    Margin="16,8,12,12"
                    Foreground="{StaticResource NavigationGroupLabelBrush}"
                    Text="0.1.4-(0)" />
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <NavigationViewItemHeader
                    Content="工作台"
                    Foreground="{StaticResource NavigationGroupLabelBrush}" />
                <NavigationViewItem
                    Content="首页"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="home" />
                <NavigationViewItemHeader
                    Content="服务模块"
                    Foreground="{StaticResource NavigationGroupLabelBrush}" />
                <NavigationViewItem
                    Content="窗口管理器"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-a" />
                <NavigationViewItem
                    Content="屏幕区域检测"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-b" />
                <NavigationViewItem
                    Content="窗口同步"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-c" />
                <NavigationViewItem
                    Content="模块 D"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-d" />
                <NavigationViewItem
                    Content="模块 E"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-e" />
                <NavigationViewItem
                    Content="模块 F"
                    Foreground="{StaticResource NavigationPaneForegroundBrush}"
                    Icon="Folder"
                    Tag="module-f" />
            </NavigationView.MenuItems>

            <NavigationView.Content>
                <Frame x:Name="ContentFrame" />
            </NavigationView.Content>
        </NavigationView>
    </Grid>
</Window>
